rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can read and write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Groups collection - authenticated users can read groups they're members of or active groups
    match /groups/{groupId} {
      allow read: if request.auth != null && (
        request.auth.uid in resource.data.members ||
        resource.data.status == 'active'
      );
      allow list: if request.auth != null; // Allow listing all groups for authenticated users
      allow create: if request.auth != null;
      allow update: if request.auth != null && 
        request.auth.uid in resource.data.members;
    }
    
    // Payments collection - users can read payments for their groups
    match /payments/{paymentId} {
      allow read: if request.auth != null && 
        request.auth.uid in resource.data.members;
      allow create: if request.auth != null && 
        request.auth.uid == resource.data.userId;
    }
    
    // Beneficiary order - group members can read
    match /beneficiary_order/{orderId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    // Monthly beneficiaries - group members can read
    match /monthly_beneficiaries/{beneficiaryId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
    }
    
    // Notifications - users can read their own notifications
    match /notifications/{notificationId} {
      allow read: if request.auth != null && 
        request.auth.uid == resource.data.userId;
      allow list: if request.auth != null && 
        request.auth.uid == resource.data.userId;
      allow create: if request.auth != null;
      allow update: if request.auth != null && 
        request.auth.uid == resource.data.userId;
    }
    
    // Invitations - users can read invitations related to their groups or themselves
    match /invitations/{invitationId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.userId || 
        request.auth.uid == resource.data.groupCreatorId
      );
      allow list: if request.auth != null; // Allow listing for queries
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.userId || 
        request.auth.uid == resource.data.groupCreatorId
      );
    }
  }
}
